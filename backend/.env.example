# Copy this file to .env  (cp .env.example .env)
# All defaults below work out-of-the-box for local development.

PORT=3000
NODE_ENV=development

# SQLite database path (relative to backend/)
DB_PATH=./data/wind_monitor.db

# Elexon BMRS API base URL — no key required
BMRS_BASE_URL=https://data.elexon.co.uk/bmrs/api/v1

# Allowed frontend origin(s) — comma-separate for multiple
# Production example: https://wind-forecast-monitor.vercel.app
FRONTEND_URL=http://localhost:5173

# Background data refresh — cron format (default: every 6 hours)
CRON_SCHEDULE=0 */6 * * *
